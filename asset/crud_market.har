            "mimeType": "text/javascript",
            "text": "import { createHotContext as __vite__createHotContext } from \"/@vite/client\";import.meta.hot = __vite__createHotContext(\"/src/index.css\");import { updateStyle as __vite__updateStyle, removeStyle as __vite__removeStyle } from \"/@vite/client\"\nconst __vite__id = \"/Users/natdanaichinsomboon/Documents/crud-demo/frontend/src/index.css\"\nconst __vite__css = \"/* @import \\\"https://cdn.jsdelivr.net/npm/bulma@1.0.4/css/bulma.min.css\\\"; */\\n\\n/* ── CSS Variables ── */\\n\\n:root {\\n  --bg:       #f8f8f6;\\n  --surface:  #ffffff;\\n  --border:   #e4e4e0;\\n  --text:     #1a1a18;\\n  --muted:    #6b6b66;\\n  --accent:   #2563eb;\\n  --accent-h: #1d4ed8;\\n  --danger:   #dc2626;\\n  --danger-h: #b91c1c;\\n  --success:  #16a34a;\\n  --radius:   8px;\\n  --mono:     \\\"JetBrains Mono\\\", \\\"Fira Code\\\", monospace;\\n}\\n\\n/* ── Layout ── */\\n\\n.app { max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem; }\\n\\n.layout { display: grid; grid-template-columns: 1fr 320px; gap: 1.5rem; align-items: start; }\\n\\nheader {\\n  display: flex;\\n  align-items: baseline;\\n  gap: 12px;\\n  margin-bottom: 2rem;\\n  padding-bottom: 1rem;\\n  border-bottom: 1px solid var(--border);\\n}\\n\\nheader h1 { font-size: 20px; font-weight: 600; letter-spacing: -0.3px; }\\n\\n/* ── Custom components (no Bulma equivalent) ── */\\n\\n.badge {\\n  font-size: 11px; font-weight: 500;\\n  padding: 2px 8px; border-radius: 99px;\\n  background: #dbeafe; color: #1e40af;\\n}\\n\\n.status-dot {\\n  width: 7px; height: 7px; border-radius: 50%;\\n  background: #d1d5db; display: inline-block;\\n  margin-left: auto; transition: background .3s;\\n}\\n\\n.status-dot.online { background: var(--success); box-shadow: 0 0 0 2px #bbf7d0; }\\n\\n/* ── User / Ingredient list ── */\\n\\n.user-list { list-style: none; }\\n\\n.user-row {\\n  display: flex; align-items: center; gap: 12px;\\n  padding: 12px 16px; border-bottom: 1px solid var(--border); transition: background .1s;\\n}\\n\\n.user-row:last-child { border-bottom: none; }\\n\\n.user-row:hover { background: var(--bg); }\\n\\n.avatar {\\n  width: 36px; height: 36px; border-radius: 50%;\\n  background: #dbeafe; color: #1e40af;\\n  font-weight: 600; font-size: 13px;\\n  display: flex; align-items: center; justify-content: center; flex-shrink: 0;\\n}\\n\\n.user-info { flex: 1; min-width: 0; }\\n\\n.user-name { font-weight: 500; font-size: 14px; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\\n\\n.user-email { font-size: 12px; color: var(--muted); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }\\n\\n.role-pill {\\n  font-size: 11px; padding: 2px 8px; border-radius: 99px;\\n  border: 1px solid var(--border); color: var(--muted); white-space: nowrap;\\n}\\n\\n.user-actions { display: flex; gap: 6px; }\\n\\n/* ── Empty state ── */\\n\\n.empty { padding: 3rem 1rem; text-align: center; color: var(--muted); }\\n\\n.empty .icon { font-size: 32px; margin-bottom: 8px; }\\n\\n/* ── Custom button variants (Bulma ใช้ .button .is-* แทนได้) ── */\\n\\n.btn-primary { background: var(--accent); color: white; }\\n\\n.btn-primary:hover { background: var(--accent-h); }\\n\\n.btn-danger  { background: transparent; color: var(--danger); border: 1px solid #fecaca; padding: 4px 10px; font-size: 12px; }\\n\\n.btn-danger:hover { background: #fef2f2; }\\n\\n.btn-edit    { background: transparent; color: var(--muted); border: 1px solid var(--border); padding: 4px 10px; font-size: 12px; }\\n\\n.btn-edit:hover { background: var(--bg); color: var(--text); }\\n\\n.btn-sm { padding: 4px 10px; font-size: 12px; }\\n\\n/* ── Form layout helpers (Bulma ใช้ .field .control แทนได้) ── */\\n\\n.form-body { padding: 16px; display: flex; flex-direction: column; gap: 14px; }\\n\\n.form-group { display: flex; flex-direction: column; gap: 5px; }\\n\\n.form-actions { display: flex; gap: 8px; padding: 12px 16px; border-top: 1px solid var(--border); }\\n\\n/* ── API Log ── */\\n\\n.log-list { list-style: none; font-family: var(--mono); font-size: 11px; max-height: 280px; overflow-y: auto; }\\n\\n.log-entry {\\n  padding: 7px 14px; border-bottom: 1px solid var(--border);\\n  display: grid; grid-template-columns: auto 1fr auto; gap: 8px; align-items: center; line-height: 1.4;\\n}\\n\\n.log-entry:last-child { border-bottom: none; }\\n\\n.log-method { font-weight: 700; font-size: 10px; padding: 1px 5px; border-radius: 3px; letter-spacing: 0.5px; }\\n\\n.GET    { background: #dbeafe; color: #1e40af; }\\n\\n.POST   { background: #dcfce7; color: #166534; }\\n\\n.PUT    { background: #fef9c3; color: #854d0e; }\\n\\n.DELETE { background: #fce8e8; color: #991b1b; }\\n\\n.log-path { color: var(--text); }\\n\\n.log-status { color: var(--muted); font-size: 10px; }\\n\\n.log-status.ok { color: var(--success); }\\n\\n.log-status.err { color: var(--danger); }\\n\\n/* ── Toast ── */\\n\\n.toast-wrap { position: fixed; bottom: 24px; right: 24px; display: flex; flex-direction: column; gap: 8px; z-index: 100; }\\n\\n.toast {\\n  padding: 10px 16px; border-radius: 8px; font-size: 13px; font-weight: 500;\\n  color: white; animation: slideUp .2s ease; max-width: 280px;\\n}\\n\\n.toast.success { background: var(--success); }\\n\\n.toast.error   { background: var(--danger); }\\n\\n@keyframes slideUp { from { transform: translateY(8px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }\\n\\n/* ── Spinner (Bulma มี .loader แต่ animation ต่างกัน) ── */\\n\\n.spinner {\\n  width: 16px; height: 16px;\\n  border: 2px solid #e5e7eb; border-top-color: var(--accent);\\n  border-radius: 50%; animation: spin .6s linear infinite; display: inline-block;\\n}\\n\\n@keyframes spin { to { transform: rotate(360deg); } }\\n\\n.loading-row { display: flex; align-items: center; gap: 10px; padding: 24px 16px; color: var(--muted); font-size: 13px; }\\n\\n/* ──────────────────────────────────────────────────────────────\\n   Override CSS (ใช้เมื่อจำเป็น — ชนกับ Bulma ทั้งหมด uncomment เมื่อต้องการ)\\n   ────────────────────────────────────────────────────────────── */\\n\\n/* *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; } */\\n\\n/* body {\\n  font-family: -apple-system, BlinkMacSystemFont, \\\"Segoe UI\\\", sans-serif;\\n  background: var(--bg);\\n  color: var(--text);\\n  font-size: 14px;\\n  line-height: 1.6;\\n  min-height: 100vh;\\n} */\\n\\n/* button {\\n  cursor: pointer;\\n  border: none;\\n  border-radius: 6px;\\n  font-size: 13px;\\n  font-weight: 500;\\n  padding: 6px 14px;\\n  transition: background .15s, opacity .15s;\\n}\\nbutton:disabled { opacity: 0.5; cursor: not-allowed; } */\\n\\n/* label { font-size: 12px; font-weight: 500; color: var(--muted); } */\\n\\n/* input, select {\\n  border: 1px solid var(--border);\\n  border-radius: 6px;\\n  padding: 8px 10px;\\n  font-size: 13px;\\n  color: var(--text);\\n  background: var(--surface);\\n  width: 100%;\\n  transition: border-color .15s, box-shadow .15s;\\n}\\ninput:focus, select:focus {\\n  outline: none;\\n  border-color: var(--accent);\\n  box-shadow: 0 0 0 3px rgba(37,99,235,.12);\\n} */\\n\\n/* .card {\\n  background: var(--surface);\\n  border: 1px solid var(--border);\\n  border-radius: var(--radius);\\n  overflow: hidden;\\n} */\\n\\n/* .card-header {\\n  padding: 12px 16px;\\n  border-bottom: 1px solid var(--border);\\n  font-size: 12px; font-weight: 600;\\n  text-transform: uppercase; letter-spacing: 0.6px;\\n  color: var(--muted);\\n  display: flex; align-items: center; justify-content: space-between;\\n} */\\n\"\n__vite__updateStyle(__vite__id, __vite__css)\nimport.meta.hot.accept()\nimport.meta.hot.prune(() => __vite__removeStyle(__vite__id))"
