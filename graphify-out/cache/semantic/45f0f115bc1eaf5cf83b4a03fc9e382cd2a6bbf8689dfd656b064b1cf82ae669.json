{"nodes": [{"id": "context_md", "label": "CONTEXT.md Project Overview", "file_type": "document", "source_file": "CONTEXT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "concept_ingredient_domain", "label": "Ingredient Domain Model", "file_type": "concept", "source_file": "CONTEXT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Core domain entity: {id, name, unit, price, stock, category}. Managed by admin via REST. Seed lives in backend/src/models/ingredients.js; target Postgres. Units: kg/g/L/ml/pcs. Categories: Grain/Protein/Vegetable/Dairy/Spice."}, {"id": "concept_order_lifecycle", "label": "Order Lifecycle", "file_type": "concept", "source_file": "CONTEXT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Order entity: {id, studentId, items:[{ingredientId,qty}], placedAt, status}. Status transitions: pending -> confirmed -> cancelled. Cart is pre-submit UI state only, not a persisted entity."}, {"id": "concept_api_protocol_comparison", "label": "API Protocol Comparison (REST vs GQL vs gRPC)", "file_type": "rationale", "source_file": "CONTEXT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "REST for ingredient CRUD (resource-first, easy HTTP verb demo), GQL for meal planning queries (flexible nested queries, schema-first contrast), gRPC for order submission at peak (high-throughput streaming for 5k weekly burst). Same data, different mental models."}, {"id": "concept_peak_load", "label": "Peak Load Design Constraint", "file_type": "rationale", "source_file": "CONTEXT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "~5,000 students access simultaneously once per week (weekly spike, NOT daily noon spike). Backen